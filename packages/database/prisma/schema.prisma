datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  firstName      String
  lastName       String
  phone          String
  nationality    String
  governorate    String
  birthday       DateTime      @db.Date
  gender         Gender
  studentStatus  StudentStatus
  university     String
  graduationYear Int
  faculty        String
  role           Role          @default(USER)
  archived       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  resetRequests PasswordResetRequest[]

  referredByCodeId String?
  referredByCode   ReferralCode? @relation("UserReferredBy", fields: [referredByCodeId], references: [id])

  applications       ProgramApplication[]
  ownedReferralCodes ReferralCode[]       @relation("UserOwnsCode")
}

model PasswordResetRequest {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     ResetRequestStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  resolvedAt DateTime?

  @@index([status])
}

enum Role {
  ADMIN
  USER
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  STUDENT
  GRADUATE
}

enum ResetRequestStatus {
  PENDING
  RESOLVED
}

model Program {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitleEn  String
  subtitleAr  String?
  logoUrl     String
  imageAspect String   @default("16:6")
  aboutBody   String
  phases      Json
  benefits    String[]
  criteria    String[]
  partnerName    String
  partnerBio     String
  partnerLogoUrl String?
  sponsors       Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  formId String?
  form   ProgramForm? @relation(fields: [formId], references: [id])

  applications  ProgramApplication[]
  referralCodes ReferralCode[]
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ProgramApplication {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId String
  program   Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  status    ApplicationStatus @default(PENDING)
  attendedAt DateTime?
  answers   Json?
  createdAt DateTime          @default(now())

  referralCodeId String?
  referralCode   ReferralCode? @relation(fields: [referralCodeId], references: [id])

  @@unique([userId, programId])
}

enum FormFieldType {
  SHORT_TEXT
  LONG_TEXT
  EMAIL
  PHONE
  NUMBER
  DROPDOWN
  CHECKBOXES
  YES_NO
  DATE
  FILE
}

model ProgramForm {
  id        String             @id @default(cuid())
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  fields   ProgramFormField[]
  programs Program[]
}

model ProgramFormField {
  id       String        @id @default(cuid())
  formId   String
  form     ProgramForm   @relation(fields: [formId], references: [id], onDelete: Cascade)
  label    String
  type     FormFieldType
  required Boolean       @default(false)
  options  String[]
  order    Int
}

enum ReferralCodeType {
  PERSONAL
  CUSTOM
}

enum ReferralSource {
  FACEBOOK
  INSTAGRAM
  GOOGLE
  EMAIL
  OTHER
}

model ReferralCode {
  id           String           @id @default(cuid())
  code         String           @unique
  type         ReferralCodeType
  label        String?
  source       ReferralSource   @default(OTHER)
  campaignName String?
  programId    String?
  program      Program?         @relation(fields: [programId], references: [id], onDelete: Cascade)
  ownerUserId  String?
  ownerUser    User?            @relation("UserOwnsCode", fields: [ownerUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  referredUsers       User[]               @relation("UserReferredBy")
  events              ReferralEvent[]
  programApplications ProgramApplication[]

  @@unique([ownerUserId, programId])
}

enum ReferralEventType {
  CLICK
  SIGNUP
  APPLICATION
}

model ReferralEvent {
  id                   String            @id @default(cuid())
  referralCodeId       String
  referralCode         ReferralCode      @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)
  type                 ReferralEventType
  userId               String?
  programApplicationId String?
  createdAt            DateTime          @default(now())
}

enum ArticleCategory {
  CAREER_HACKS
  JOB_SEARCH
  DAY_IN_THE_LIFE
  GUIDE
}

model Article {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  category    ArticleCategory
  body        String
  publishedAt DateTime
  createdAt   DateTime        @default(now())
}

enum EventType {
  INFO_SESSION
  TRAINING
  WORKSHOP
  CAREER_DAY
  RECRUITMENT_DAY
  EMPLOYER_CIRCLE
  CAREER_ADVISING
  CAREER_TALK
  EMPLOYMENT_FAIR
  MENTORSHIP_CIRCLE
  CAREER_WEEK
  OTHER
}

model Event {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  type      EventType
  startsAt  DateTime
  location  String
  body      String
  createdAt DateTime  @default(now())
}

model Company {
  id                String   @id @default(cuid())
  name              String
  numberOfEmployees String
  industry          String
  type              String
  description       String
  address           String
  benefits          String[]
  logoUrl           String?
  linkedinUrl       String?
  facebookUrl       String?
  websiteUrl        String?
  documentUrls      String[]
  createdAt         DateTime @default(now())

  employerUsers EmployerUser[]
}

model EmployerUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String
  jobTitle     String
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

enum DashboardUserRole {
  ADMIN
}

model DashboardUser {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  passwordHash String
  role         DashboardUserRole @default(ADMIN)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}
